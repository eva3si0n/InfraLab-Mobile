<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31). Never back up or device-transfer the encrypted secure_prefs: its Tink
     keyset is wrapped by a hardware Keystore master key that does NOT travel, so a restored keyset
     is undecryptable and crashed the app on launch (AEADBadTagException). Tokens are re-seeded from
     the bundled seed.json, so excluding it loses nothing. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
